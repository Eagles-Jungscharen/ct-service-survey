# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# ========================================
# Note: All frontend variables must be prefixed with VITE_

# ChurchTools OIDC Configuration
VITE_OIDC_AUTHORITY=https://authentication.your-church.church.tools/api/oidc
VITE_OIDC_CLIENT_ID=your-client-id
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# API Configuration
VITE_API_BASE_URL=http://localhost:7072

# ========================================
# BACKEND ENVIRONMENT VARIABLES
# ========================================

# Azure Functions Core
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=dotnet-isolated

# Application Insights (optional for local development)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ChurchTools Configuration
CHURCHTOOL_URL=https://your-church.church.tools
OIDC_AUTHORITY_URL=https://authentication.your-church.church.tools/api/oidc

# ChurchTools IDP Services
CHURCHTOOL_IDP_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
CHURCHTOOL_IDP_BASE_URL=https://your-idp-function.azurewebsites.net
CHURCHTOOL_IDP_FUNCTION_KEY=your-function-key

# Admin Configuration
CHURCHTOOL_ADMIN_GROUP_ID=your-admin-group-id

# Survey Storage Configuration
SURVEY_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
